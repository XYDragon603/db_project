SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/medminder
SPRING_DATASOURCE_USERNAME=medminder_user
SPRING_DATASOURCE_PASSWORD=change_me
DB_INIT_MODE=never
FRONTEND_ORIGIN=http://localhost:5173

# Optional local fallback values
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medminder
DB_USERNAME=medminder_user
DB_PASSWORD=change_me

SPRING_PROFILES_ACTIVE=default
VITE_API_BASE_URL=http://localhost:8080/api
VITE_ENABLE_MOCK_FALLBACK=false

# Render PostgreSQL example
# SPRING_DATASOURCE_URL=postgresql://<render-user>:<render-password>@<render-host>/<render-db>
# SPRING_DATASOURCE_USERNAME=<render-user>
# SPRING_DATASOURCE_PASSWORD=<render-password>
# FRONTEND_ORIGIN=https://<your-frontend>.onrender.com
# VITE_API_BASE_URL=https://<your-backend>.onrender.com/api
